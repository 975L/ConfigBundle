{#
 # Renders the dashboard shortcuts (see c975L\ConfigBundle\Management\ShortcutBuilder) as a grid of small
 # tiles (icon on top, label below) rather than a row of pill buttons - reads as a "quick actions" panel
 # instead of a wall of buttons once several bundles each contribute a few.
 # Expects:
 #   - shortcuts: array of ['label', 'icon', 'route', 'active']
 # Each shortcut is a POST form (not a plain link) since it triggers an action, protected by its own CSRF token
 # Caller is responsible for checking shortcuts|length > 0 (see management/index.html.twig)
 #}
<div class="shortcuts-grid">
{% for shortcut in shortcuts %}
    {% if shortcut.role is defined and is_granted(shortcut.role) %}
        <form method="post" action="{{ path(shortcut.route) }}">
            <input type="hidden" name="_token" value="{{ csrf_token(shortcut.route) }}">
            <button type="submit" class="shortcut-tile{{ shortcut.active ? ' shortcut-tile-active' : '' }}">
                <i class="{{ shortcut.icon }}"></i>
                <span>{{ shortcut.label }}</span>
            </button>
        </form>
    {% endif %}
{% endfor %}
</div>
