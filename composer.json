{
    "name": "c975l/config-bundle",
    "type": "symfony-bundle",
    "description": "A Symfony bundle that stores application configuration as key-value pairs in the database, with an EasyAdmin management interface, Twig/PHP accessors, and production deployment tooling.",
    "keywords": ["symfony", "bundle", "config"],
    "homepage": "https://github.com/975L/ConfigBundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Laurent Marquet",
            "email": "laurent.marquet@laposte.net",
            "homepage": "https://github.com/LaurentMarquet",
            "role": "Developer"
        },
        {
            "name": "975L Community",
            "homepage": "https://github.com/975L"
        }
    ],
    "require": {
        "php": ">=8.0",
        "doctrine/orm": "*",
        "c975l/ui-bundle": "*",
        "easycorp/easyadmin-bundle": "*",
        "sensiolabs/minify-bundle": "*",
        "symfony/form": "*",
        "symfony/serializer": "*",
        "symfony/yaml": "*"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "*",
        "phpunit/phpunit": "^13.2",
        "symfony/browser-kit": "*",
        "symfony/css-selector": "*",
        "symfony/phpunit-bridge": "*",
        "symfony/var-dumper": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "c975L\\ConfigBundle\\": "src/",
            "c975L\\ConfigBundle\\Migrations\\": "migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "c975L\\ConfigBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "vendor-dir": ".vendor"
    },
    "scripts": {
        "test": "phpunit"
    },
    "support": {
        "email": "contact@975l.com",
        "source": "https://github.com/975L/ConfigBundle",
        "issues": "https://github.com/975L/ConfigBundle/issues"
    }
}
